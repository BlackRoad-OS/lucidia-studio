# ─────────────────────────────────────────────────────────────
# Lucidia Studio — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.
# ─────────────────────────────────────────────────────────────

# ── NextAuth ────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
# Public URL of this deployment (no trailing slash)
NEXTAUTH_URL=https://lucidia.studio

# ── OAuth Providers ─────────────────────────────────────────
# GitHub → https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google → https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI API Gateway ──────────────────────────────────────────
# Point to your own relay/gateway (Cloudflare Worker, Tailscale
# node, local proxy, etc.) instead of calling vendors directly.
# Must expose an OpenAI-compatible /chat/completions endpoint.
# Example (local): http://localhost:8080
# Example (Cloudflare): https://ai-gateway.example.workers.dev
AI_API_BASE_URL=https://ai-gateway.example.com
AI_API_KEY=your-api-key-here

# ── Stripe ──────────────────────────────────────────────────
# Dashboard → https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Dashboard → Developers → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for your subscription product
STRIPE_PRICE_ID=price_...
